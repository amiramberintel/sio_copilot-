# ─────────────────────────────────────────────────────────────────────────────
#  PT SESSION LOADING (all via NetBatch)
# ─────────────────────────────────────────────────────────────────────────────
# Base NB loader (from ahaimovi) - usage: loadptnb_cth <session_path> <title>
alias loadptnb_cth 'nbjob run --class "SLES15SP4&&256G&&4C" --qslot bc15_gfc_fct --target sc8_express /p/hdk/pu_tu/prd/fct_alias/latest/utils/load_session_cth.csh \!:1 -title \!:2'

