alias loadpt_golden_nb 'loadptnb_cth $PROJ_ARCHIVE/arc/\!:1/sta_primetime/GOLDEN/*.\!:2.* "\!:1_\!:2_GOLDEN"'

# Load from daily model (usage: loadpt_daily_nb max_high)
alias loadpt_daily_nb  'loadptnb_cth $links/$model/runs/$block/$tech/sta_pt/func.\!:1.T_85.typical/outputs/$block.pt_session.func.\!:1.T_85.typical "${par}_\!:1_daily"'

# Load from latest release model (usage: loadpt_latest_nb max_high)
